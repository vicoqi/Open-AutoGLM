# Phone Agent Server 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ============================================
# WebSocket 服务器配置
# ============================================
PHONE_AGENT_WS_HOST=0.0.0.0
PHONE_AGENT_WS_PORT=8765
PHONE_AGENT_WS_MAX_CONNECTIONS=10
PHONE_AGENT_WS_HEARTBEAT_INTERVAL=30
PHONE_AGENT_WS_TASK_TIMEOUT=300

# ============================================
# 模型配置
# ============================================
# 本地模型服务
PHONE_AGENT_BASE_URL=http://localhost:8000/v1
PHONE_AGENT_MODEL=autoglm-phone-9b
PHONE_AGENT_API_KEY=EMPTY

# 或使用智谱 BigModel（取消注释并填入你的 API Key）
# PHONE_AGENT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# PHONE_AGENT_MODEL=autoglm-phone
# PHONE_AGENT_API_KEY=your-api-key-here

# 或使用 ModelScope（取消注释并填入你的 API Key）
# PHONE_AGENT_BASE_URL=https://api-inference.modelscope.cn/v1
# PHONE_AGENT_MODEL=ZhipuAI/AutoGLM-Phone-9B
# PHONE_AGENT_API_KEY=your-api-key-here

# ============================================
# 设备配置
# ============================================
PHONE_AGENT_DEVICE_TYPE=adb
# PHONE_AGENT_DEVICE_ID=  # 留空自动检测
PHONE_AGENT_LANG=cn
PHONE_AGENT_MAX_STEPS=100

# ============================================
# 日志配置
# ============================================
PHONE_AGENT_LOG_LEVEL=INFO
